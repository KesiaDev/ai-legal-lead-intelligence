// Prisma schema for Super SDR Jurídico (SaaS Multi-Tenant)
// Compatible with Fastify + Railway + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////
// CORE – TENANT  //
////////////////////

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  leads     Lead[]
  pipelines PipelineStage[]

  @@index([plan])
}

////////////////////
// USERS          //
////////////////////

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("user") // admin | user | sdr
  isActive  Boolean  @default(true)

  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([role])
}

////////////////////
// LEADS (CORE)   //
////////////////////

model Lead {
  id                        String   @id @default(uuid())

  tenantId                  String
  tenant                    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name                      String
  phone                     String
  email                     String?

  city                      String?
  state                     String?

  legalArea                 String?
  customLegalArea           String?
  demandDescription         String?  @db.Text

  urgency                   String?  // baixa | media | alta | urgente

  status                    String   @default("novo")
  // novo | em_triagem | qualificado | consulta_agendada | compareceu
  // contrato_enviado | contrato_assinado | perdido

  contactPreference         String?
  availableForHumanContact  Boolean  @default(true)

  lgpdConsent               Boolean  @default(false)
  lgpdConsentDate           DateTime?

  scheduledContact          DateTime?

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  conversations             Conversation[]
  pipelineHistory           PipelineHistory[]

  @@index([tenantId])
  @@index([status])
  @@index([legalArea])
}

////////////////////
// CONVERSATIONS  //
////////////////////

model Conversation {
  id            String   @id @default(uuid())

  tenantId      String

  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel       String   // whatsapp | chat | email | instagram
  assignedType  String   @default("ai") // ai | human | hybrid
  status        String   @default("active") // active | paused | closed

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      Message[]

  @@index([tenantId])
  @@index([leadId])
  @@index([channel])
}

////////////////////
// MESSAGES       //
////////////////////

model Message {
  id             String   @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  content        String   @db.Text
  senderType     String   // lead | sdr | ai

  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([senderType])
}

////////////////////
// PIPELINE       //
////////////////////

model PipelineStage {
  id        String   @id @default(uuid())

  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  order     Int
  color     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

model PipelineHistory {
  id        String   @id @default(uuid())

  tenantId  String

  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  stageName String
  changedBy String?  // userId ou 'ai'
  notes     String?  @db.Text

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([leadId])
}

