// Prisma schema for Super SDR Jurídico (SaaS Multi-Tenant)
// Compatible with Fastify + Railway + PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////
// CORE – TENANT  //
////////////////////

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  leads           Lead[]
  pipelines       Pipeline[]
  deals           Deal[]
  crmIntegrations CrmIntegration[]
  agentPrompts    AgentPrompt[]
  voiceConfigs    VoiceConfig[]
  integrationConfig IntegrationConfig?

  @@index([plan])
}

////////////////////
// USERS          //
////////////////////

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String
  password String
  role     String  @default("user") // admin | user | sdr
  isActive Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([role])
}

////////////////////
// LEADS (CORE)   //
////////////////////

model Lead {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name  String
  phone String
  email String?

  city  String?
  state String?

  legalArea         String?
  customLegalArea   String?
  demandDescription String? @db.Text

  urgency String? // baixa | media | alta | urgente

  status String @default("novo")
  // novo | em_triagem | qualificado | consulta_agendada | compareceu
  // contrato_enviado | contrato_assinado | perdido

  contactPreference        String?
  availableForHumanContact Boolean @default(true)

  lgpdConsent     Boolean   @default(false)
  lgpdConsentDate DateTime?

  scheduledContact DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations   Conversation[]
  pipelineHistory PipelineHistory[]
  deals           Deal[]

  @@index([tenantId])
  @@index([status])
  @@index([legalArea])
}

////////////////////
// CONVERSATIONS  //
////////////////////

model Conversation {
  id String @id @default(uuid())

  tenantId String

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  channel      String // whatsapp | chat | email | instagram
  assignedType String @default("ai") // ai | human | hybrid
  status       String @default("active") // active | paused | closed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([tenantId])
  @@index([leadId])
  @@index([channel])
}

////////////////////
// MESSAGES       //
////////////////////

model Message {
  id String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  content    String @db.Text
  senderType String // lead | sdr | ai

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([senderType])
}

////////////////////
// PIPELINE       //
////////////////////

model Pipeline {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String // "Black Friday", "Educacional", "Parceria", "Projetos"
  description String?
  isActive    Boolean @default(true)
  color       String? // Cor do pipeline

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages PipelineStage[]
  deals  Deal[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isActive])
}

model PipelineStage {
  id String @id @default(uuid())

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  name  String // "LEAD MAPEADO", "CONTATO REALIZADO", etc.
  order Int // Ordem no funil
  color String? // Cor da etapa

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals   Deal[]
  history PipelineHistory[]

  @@unique([pipelineId, name])
  @@index([pipelineId])
  @@index([order])
}

model Deal {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  title    String // Título do negócio
  value    Float? // Valor do negócio
  currency String @default("BRL") // BRL, USD, EUR

  // Dados do CRM externo (para sincronização)
  crmId   String? // ID no CRM externo (Pipedrive, Advbox, etc.)
  crmType String? // "pipedrive", "advbox", "hubspot", etc.
  crmData Json? // Dados adicionais do CRM

  assignedTo String? // userId
  notes      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  history PipelineHistory[]

  @@index([tenantId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([leadId])
  @@index([crmId, crmType])
}

model PipelineHistory {
  id String @id @default(uuid())

  tenantId String

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  stageName String
  changedBy String? // userId ou 'ai'
  notes     String? @db.Text

  createdAt       DateTime       @default(now())
  PipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])
  pipelineStageId String?

  @@index([tenantId])
  @@index([leadId])
  @@index([dealId])
}

////////////////////
// CRM INTEGRATION//
////////////////////

model CrmIntegration {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type     String // "pipedrive", "advbox", "hubspot", "salesforce", "zoho", etc.
  name     String // Nome da integração
  isActive Boolean @default(true)

  // Credenciais (criptografadas)
  apiKey      String? // API Key ou Token
  apiSecret   String? // API Secret (se necessário)
  apiUrl      String? // URL base da API
  workspaceId String? // ID do workspace no CRM

  // Configurações
  syncDirection String  @default("bidirectional") // "bidirectional", "to_crm", "from_crm"
  autoSync      Boolean @default(true)
  syncInterval  Int     @default(3600) // Segundos

  // Mapeamento de campos
  fieldMapping Json? // Mapeamento de campos entre sistemas

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSyncAt DateTime?

  @@unique([tenantId, type, workspaceId])
  @@index([tenantId])
  @@index([type])
  @@index([isActive])
}

////////////////////
// AGENT PROMPTS  //
////////////////////

model AgentPrompt {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  type        String // orquestrador | qualificador | scheduler | resumo | followup | insights | etc.
  version     String @default("v1.0")
  status      String @default("ativo") // ativo | inativo
  provider    String @default("OpenAI") // OpenAI | Google
  model       String @default("gpt-4o-mini")
  temperature Float? @default(0.4)
  maxTokens   Int?   @default(500)
  content     String @db.Text // Conteúdo do prompt

  description String? @db.Text
  objective   String? @db.Text
  limits      Json? // Array de limites/regras
  tone        String?
  outputSchema String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type, version])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([tenantId, type, status])
}

////////////////////
// VOICE CONFIG   //
////////////////////

model VoiceConfig {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Provider de voz
  provider String @default("elevenlabs") // elevenlabs | google | azure | none
  
  // API Key do ElevenLabs
  elevenlabsApiKey String?
  
  // ID da voz selecionada
  voiceId   String
  voiceName String
  
  // Probabilidades de resposta em áudio
  audioResponseProbabilityOnText  String @default("nunca") // nunca | baixa | media | alta | sempre
  audioResponseProbabilityOnAudio String @default("alta")
  audioResponseProbabilityOnMedia String @default("baixa")
  
  // Duração máxima do áudio em segundos
  maxAudioDuration Int @default(60)
  
  // Ajuste de texto para linguagem falada
  textToSpeechAdjustment String @default("moderado") // desativado | pouco | moderado
  
  // Palavras que forçam resposta em texto (JSON array)
  textOnlyKeywords Json? @default("[]")
  
  // Configurações de voz (ElevenLabs)
  voiceStability      Float @default(0.5)
  voiceSimilarityBoost Float @default(0.75)
  voiceStyle          Float @default(0.3)
  voiceSpeed          Float @default(1.0)
  
  // Ativado/desativado
  enabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
  @@index([enabled])
}

////////////////////
// INTEGRATION CONFIG //
////////////////////

model IntegrationConfig {
  id String @id @default(uuid())

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // OpenAI
  openaiApiKey String? // API Key da OpenAI (criptografada)

  // N8N (opcional, para workflows externos)
  n8nWebhookUrl String?

  // Evolution API (legado, pode ser removido)
  evolutionApiUrl    String?
  evolutionApiKey    String?
  evolutionInstance String?

  // Z-API (já configurado via env vars, mas pode ser por tenant no futuro)
  zapiInstanceId String?
  zapiToken      String?
  zapiBaseUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}
