{
  "name": "sdr-juridico-backend",
  "version": "1.0.0",
  "description": "Backend API para SDR Jurídico",
  "main": "src/server.ts",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "prisma db push --accept-data-loss && prisma generate && tsx src/server.ts",
    "start:direct": "tsx src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:resolve-migration": "prisma migrate resolve --applied 20250120000000_add_pipelines_and_deals || true",
    "db:seed": "tsx src/prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/jwt": "^7.2.4",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.19.1",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "nodemailer": "^8.0.3",
    "openai": "^4.47.1",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "prisma": "^5.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
